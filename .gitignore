__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/

# NOTE: uv.lock IS committed (lockfile policy).

# ── JavaScript / TypeScript ─────────────────────
node_modules/
package-lock.json

# ── Java (Maven) ────────────────────────────────
target/
*.class
*.jar
*.war

# ── C# / .NET ──────────────────────────────────
bin/
obj/

# ── Ruby ────────────────────────────────────────
Gemfile.lock
vendor/bundle/

# ── Rust ────────────────────────────────────────
**/rust/target/
Cargo.lock

